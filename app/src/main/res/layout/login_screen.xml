<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ImmunoBuddy"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="#111" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Effettua il login"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:textColor="#111" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inserisci e-mail e password"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/emailLogin"
            android:hint="email@domain.com"
            android:inputType="textEmailAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/editbox_background" />

        <EditText
            android:id="@+id/passwordLogin"
            android:hint="Password"
            android:inputType="textPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@android:drawable/editbox_background" />

        <Button
            android:id="@+id/loginButton"
            android:text="Login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#1E293B"
            android:textColor="#fff" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/toRegister"
            android:text="Sei un nuovo utente? Crea il tuo account"
            android:textSize="14sp"
            android:textColor="#2563EB"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />
        <Button
            android:id="@+id/googleLoginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continua con Google"
            android:drawableStart="@drawable/ic_google"
            android:padding="12dp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            android:elevation="4dp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/appleLoginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continua con Apple"
            android:drawableStart="@drawable/ic_apple"
            android:padding="12dp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            android:elevation="4dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>

